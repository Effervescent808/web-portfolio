---
import { Image } from 'astro:assets';
import Blackjack from '../../images/blackjack.png';
import GithubImage from '../../assets/github.svg';
import Page from '../../assets/page.svg';
import JavaScript from '../../assets/javascript.svg';
import Html from '../../assets/html.svg';
import Css from '../../assets/css.svg';

const { slug } = Astro.props;
---

<div id="projectPage">
	<div id="hero" class="box">
		<Image
			src={Blackjack}
			alt="Blackjack"
			transition:name={`project-img-${slug}`}
			style="border-radius: 10px; border: 2px solid black; width: 100%; height: auto;"
		/>
	</div>

	<div id="projectDetails" class="box">
		<div id="projectHeader">
			<h1>Blackjack on the Web</h1>
			<div>
				<a class="sourcetag" href="https://Effervescent808.github.io" target="_blank">
					<p>Demo</p>
					<img src={Page.src} style="width: 20px;">
				</a>
				<a class="sourcetag" href="https://github.com/Effervescent808/Effervescent808.github.io" target="_blank">
					<p>Source</p>
					<img src={GithubImage.src} style="width: 20px;">
				</a>
			</div>
		</div>

		<div class="tags">
			<div class="tag">JavaScript<p></p><img src={JavaScript.src} style="width: 20px;"></div>
			<div class="tag"><p>HTML</p><img src={Html.src} style="width: 20px;"></div>
			<div class="tag"><p>CSS</p><img src={Css.src} style="width: 20px;"></div>
		</div>

		<div id="projectBody">
			<div class="textDiv">
				<h2>Overview</h2>
				<p class="projectBody">Blackjack for the web is a simple blackjack simulation where you play 1 on 1 against the dealer with fake money.</p>
			</div>
			<div class="textDiv">
				<h2>Features</h2>
				<ul class="outerList">
					<li>ALL IN BUTTON
						<ul class="innerList">
							<li>Go all in with just the click of a button</li>
						</ul>
					</li>
					<li>Name based accounts
						<ul class="innerList">
							<li>Sign in with the same name every time to play with the same set of fake money</li>
						</ul>
					</li>
					<li>Total Counters
						<ul class="innerList">
							<li>Let the website count your totals for you </li>
						</ul>
					</li>
				</ul>
			</div>
		</div>
	</div>
</div>

<style>
/* Body Style */
  	#projectPage {
    		width: 100%;
		display: flex;
		justify-content: center;
		padding: 2% 14%;
		padding-top: 5%;
		flex-direction: column;
		gap: 35px;
  	}
	.box {
    		display: flex;
    		height: auto;
    		box-sizing: border-box;
    		border: 2px solid #7686a6;
    		border-radius: 16px;
    		padding: 15px;
  	}
  	#hero {
    		padding: 10px;
  	}
  	#projectDetails {
    		flex-direction: column;
    		gap: 20px;
  	}
  	#projectHeader {
    		display: flex;
    		justify-content: space-between;
    		align-items: center;
		border-bottom: 2px solid #7686a6;
		color: #ffa066;
  	}

/* Body Text */
  	h1 {
    		font-size: 50px;
    		margin: 0;
  	}
	h2 {
		font-size: 40px;
		color: #ffa066;
		margin: 0;
		text-align: center;
	}
	.projectBody {
    		color: #96a5c3;
	}
  	#projectBody {
		display: flex;
		flex-direction: column;
		gap: 20px;
		padding: 2% 20%;
		font-size: 20px;
  	}
	.textDiv {
		display: flex;
		flex-direction: column;
		gap: 20px;
		padding: 0 30px 40px 30px;
		border-bottom: 2px solid #7686a6;
	}
	.outerList {
		list-style-type: disc;
		padding: 10px 30px;
	}
	.innerList {
		list-style-type: circle;
		padding: 10px;
	}

/* Tags */
  	.tags {
    		display: flex;
    		gap: 5px;
    		flex-wrap: wrap;
  	}
  	.tag {
    		border: 2px solid #7686a6;
    		border-radius: 7px;
    		padding: 2px 5px;
    		display: inline-flex;
    		gap: 5px;
  	}
  	.sourcetag {
    		border-width: 1px 3px 3px 1px;
    		border-radius: 10px;
    		padding: 7px 13px;
    		display: inline-flex;
    		gap: 5px;
    		transition: border-width 0.1s ease;
    		text-decoration: none;
    		color: inherit;
  	}
  	.sourcetag:hover {
    		border-width: 3px 1px 1px 3px;
  	}

/* mobile support */
  	@media (max-width: 600px) {
    		#projectPage {
      			padding: 2%;
    		}
    		.box {
      			padding: 2%;
    		}
  	}
</style>
