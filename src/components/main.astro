---
import CartiCat from '../images/CartiCat.jpg'
---
<!-- HTML -->

<!-- Nav Bar -->
<div class="navBar">
	<ul>
		<li><a href="Home">Home</a></li>
		<li><a href="Projects">Projects</a></li>
		<li><a href="Blog">Blog</a></li>
		<li><a href="Contact">Contact</a></li>
	</ul>
</div>

<div id="intro">
	<div class="box">
		<div class="paragraph">
			<h1>Hello, My name is Tyson!</h1>
			<p>I am a first year Computer Science student at the Illinois Institute of Technology.</p>
		</div>
		<div class="image">
			<img src={CartiCat.src} alt="Cat" width="100" height="100">
		</div>
	</div>
</div>

<!-- Style -->
<style>
/* Nav Bar */
	.navBar {
		display: flex;
		justify-content: center;
		width: 100%;
		height: 4%;
		border-bottom: 2px solid black;
	}

	ul li {
		float: left;
		list-style-type: none;
		transition: transform 0.2s ease;
	}

	ul li a {
		display: block;
		padding: 15px;
	}

	li:hover {
		transform: scale(1.5);
	}

/* Intro */
	#intro {
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 2%
	}

	.box {
		width: 75%;
		box-sizing: border-box;
		border: 2px solid black;
		border-radius: 16px;
		padding: 15px;
	}

	h1 {
		font-size: 50px;
	}

</style>

