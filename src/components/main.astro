---
import Placeholder500 from '../images/500x500.png'
import Placeholder300 from '../images/300x200.png'
import Profile from '../images/Tisen Hot Child.png'
import Jonk from '../images/Tosen.jpg'
import BearBanking from '../images/bearBanking.png'
import TuiPassmanager from '../images/tuiPassmanager.png'

import Resume from '../assets/ResumeJanuary2026.pdf'

import ResumeImage from '../assets/resume.svg'
import GithubImage from '../assets/github.svg'
import LinkedInImage from '../assets/linkedin.svg'
import EmailImage from '../assets/email.svg'

import Python from '../assets/python.svg'
import Java from '../assets/java.svg'
import JavaScript from '../assets/javascript.svg'
import Html from '../assets/html.svg'
import Css from '../assets/css.svg'
import Sqlite from '../images/sqlite.png'
import Sqlite2 from '../assets/sqlite2.svg'
import NodeJS from '../assets/nodejs.svg'
import Docker from '../assets/docker.svg'

import Talon from '../images/talon.png'
---
<!-- HTML -->

<!-- Nav Bar -->
<div class="navBar">
	<ul>
		<li><a class="nav" href="/">Home</a></li>
		<li><a class="nav" href="javascript:void(0)">Projects</a></li>
		<li><a class="nav" href="javascript:void(0)">Photography</a></li>
	</ul>
	<div class="notification"><p id="notiText"></p></div>
</div>

<div id="intro">
	<div class="box">
		<div class="paragraph">
			<h1>Hey! I'm Tyson Haufschild</h1>
			<p id="spacing1"></p>
			<p>I am currently a first year Computer Science student at the Illinois Institute of Technology.</p>
			<div id="links">
				<a id="resumeLink" href={Resume} download>
					<img src={ResumeImage.src} width="40" height="40">
				</a>
				<a href="https://github.com/Effervescent808">
					<img src={GithubImage.src} width="40" height="40">
				</a>
				<a href="https://www.linkedin.com/in/tyson-haufschild-0b0042357/">
					<img src={LinkedInImage.src} width="40" height="40">
				</a>
				<a id="email">
					<img src={EmailImage.src} style="width:100%; height: 100%;">
				</a>
				<div id="dropdown">
					<a class="email" href="mailto:thaufschild@hawk.illinoistech.edu">School Email</a>
					<a class="email" href="mailto:haufschildtyson@gmail.com">Personal Email</a>
				</div>
			</div>
		</div>
		<div class="image">
			<img src={Profile.src} width="500" height="500" style="border-radius:10px;">
		</div>
	</div>


	<div id="techlist" class="box">
		<h2>Tech Stack:</h2>
		<div id="techstack">
			<img class="techImages" src={Python.src}>
			<img class="techImages" src={Java.src}>
			<img class="techImages" src={JavaScript.src}>
			<img class="techImages" src={Html.src}>
			<img class="techImages" src={Css.src}>
			<img class="techImages" src={Sqlite.src}>
			<img class="techImages" src={NodeJS.src}>
			<img class="techImages" src={Docker.src}>
		</div>
	</div>

	<div id="bigWorkJob">
		<div id="selector">
			<button class="selectorButton" id="workButton">Work</button>
			<button class="selectorButton" id="educationButton">Education</button>
		</div>
		<div id="work" class="box hide">
			<p>None :(</p>
		</div>
		<div id="education" class="box">
			<div style="width: 100%;">
				<div class="outerWorkJob">
					<a href="https://www.iit.edu/">
						<img class="profile" src={Talon.src}>
					</a>
					<div class="innerWorkJob">
						<div class="bigHeader">
							<p>Illinois Institute of Technology</p>
						</div>
						<div class="workJobHeader">
							<p>BS in Computer Science</p>
							<time>
								<span>August 2025</span>
								<span> - </span>
								<span>Present</span>
							</time>
						</div>
						
						<div class="infoList">
							<ul>
								<li>
									<span>Member of the IIT Men's Volleyball Team</span>
									<span> - </span>
									<span>
										<a href="https://illinoistechathletics.com/sports/mvball/roster" class="link">Roster</a>
									</span>
								</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>


	<h1 style="text-align: center; padding: 50px 0px 0px 0px">Featured Projects</h1>

	<div id="featuredProjects">
		<div class="project box">
			<img src={BearBanking.src} style="border-radius: 10px; border: 2px solid black;">
			<div class="lowerProject">
				<div class="projectTitle">
					<p>Bear Banking</p>
				</div>
				<div class="projectBody">
					<p>The Bear Banking dashboard is a bear themed dashboard designed for college students to track their finances.</p>
				</div>
				<div class="tags">
					<div class="tag">
						<p>Node.js</p>
						<img src={NodeJS.src} style="width: 20px;">
					</div>
					<div class="tag">
						<p>Docker</p>
						<img src={Docker.src} style="width: 20px;">
					</div>
					<div class="tag">
						<p>HTML</p>
						<img src={Html.src} style="width: 20px;">
					</div>
					<div class="tag">
						<p>CSS</p>
						<img src={Css.src} style="width: 20px;">
					</div>
					<div class="tag">
						<p>SQLite</p>
						<img src={Sqlite2.src} style="width: 20px;">
					</div>
				</div>
			</div>
		</div>
		<div class="project box">
			<img src={TuiPassmanager.src} style="border-radius: 10px; border: 2px solid black;">
			<div class="lowerProject">
				<div class="projectTitle">
					<p>Tui Passmanager</p>
				</div>
				<div class="projectBody">
					<p>Tui Passmanager is a terminal based password manager that stores and retrieves passwords from an encrypted database. It also has password generation capabilities creating a strong random password with a length of your choice.</p>
				</div>
				<div class="tags">
					<div class="tag">
						<p>Python</p>
						<img src={Python.src} style="width: 20px;">
					</div>
					<div class="tag">
						<p>SQLite</p>
						<img src={Sqlite2.src} style="width: 20px;">
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<style>

	/* Nav Bar */
	.navBar {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
		height: 5%;
		border-bottom: 2px solid black;
	}
	ul {
		margin: 0;
		padding: 0;
	}
	.navBar ul li {
		float: left;
		list-style-type: none;
		padding: 17px;
		transition: transform 0.2s ease;
	}
	.navbar ul li a {
		display: block;
	}
	.navBar li:hover {
		transform: scale(1.5);
	}

	/* Intro */
	#intro {
		width: 100%;
		display: flex;
		justify-content: center;
		padding: 2% 14%;
		flex-direction: column;
		gap: 35px;
	}
	.box {
		display: flex;
		height: auto;
		box-sizing: border-box;
		border: 2px solid black;
		border-radius: 16px;
		padding: 15px;
	}
	#spacing1 {
		height: 50px;
	}
	#links {
		position: absolute;
		display: flex;
		gap: 25px;
		justify-content: center;
		align-items: center;
		bottom: 5px;
		left: 5px;
	}
	#links a img{
		transition: transform 0.3s ease;
	}
	#links a:hover img {
		transform: scale(1.3);
	}
	#dropdown {
		display: none;
		position: absolute;
		z-index: 10;
		top: 80%;
		left: 80%;
		background: white;
		border: 1px solid black;
		border-radius: 8px;
		padding: 5px 0;
		white-space: nowrap;
	}
	#dropdown a {
		display: block;
		padding: 6px 14px;
	}
	#email {
		position: relative;
		height: 45px;
		width: 45px;
	}
	.email:hover {
		background-color: lightgrey;
	}
	.paragraph {
		position: relative;
		width: 100%;
		text-align: center;
		padding: 50px;
		margin-right: auto;
		margin-left: auto;
	}	

	/* Tech Stack */
	#techlist, #job, #work, #education {
		justify-content: center;
		align-items: center;
		flex-direction: column;
		padding: 2%;
		gap: 20px;
	}
	#techstack {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 15px;
	}
	.techImages {
		height: 50px;
	}

	/* Work - Job */
	#bigWorkJob {
		gap: 5px;
		display: flex;
		flex-direction: column;
	}
	#selector {
		display: flex;
		justify-content: center;
		width: 100%;
	}
	.selectorButton {
		width: 50%;
		font-size: 20px;
		border: 2px solid black;
		padding: 5px;
		color: grey;
	}
	.selectorButton:hover {
		color:black;
	}
	.selectorButton.active {
		color:black;
	}
	#workButton {
		border-radius: 10px 0px 0px 10px;
	}
	#educationButton {
		border-radius: 0px 10px 10px 0px;
	}
	#work.hide {
		display: none;
	}
	#education.hide {
		display: none;
	}
	.workJobHeader {
		width: 100%;
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		column-gap: 1rem;
	}
	.profile {
		border-radius: 50%;
		border: 2px solid black;
		width: 50px;
		height: 50px;
	}
	.innerWorkJob {
		display: flex;
		flex-direction: column;
		width: 91%;
	}
	.outerWorkJob {
		display: flex;
		gap: 40px;
	}
	.infoList ul{
		list-style-type: disc;
		padding: 0px 5px;
	}
	.infoList {
		padding: 0px 10px;
	}

	/* Featured Projects */
	#featuredProjects {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 20px;
	}
	.project {
		display: flex;
		flex-direction: column;
	}
	.lowerProject {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		height: 100%;
	}
	.projectTitle {
		padding: 5px;
		font-size: 20px;
	}
	.projectBody {
		padding: 5px;
	}
	.tags {
		display: flex;
		margin-top: 20px;
		gap: 5px;
	}
	.tag {
		border: 2px solid black;
		border-radius: 7px;
		padding: 2px 5px;
		display: inline-flex;
		gap: 5px;
	}

	/* General */	
	h1 {
		font-size: 50px;
	}
	h2 {
		font-size: 25px;
	}
	.image {
		padding: 10px;
		border: 2px solid black;
		border-radius: 10px;
	}
	.link {
		color: #0000EE;
	}
	.link:hover{
		color: #8282ff;
	}
	
	/* Mobile Support */
	@media (max-width: 600px) {
		html {
			font-size:13px;
		}
		.navBar {
			height: 8%;
		}
		ul li a {
			padding: 17px 10px;
		}
		#intro {
			height: auto;
		}
		.box {
			padding: 2%;
			flex-direction: column;
			height: 90%;
		}
		.paragraph {
			padding: 35px 50px;
		}
	}

	/* Notification */
	.notification {
		position: absolute;
		right: 15px;
		text-align: center;
		border: 2px solid black;
		width: fit-content;
		padding: 10px 20px;
		border-radius: 15px;
		background-color: #1148a1;
		color: #FFFFFF;
		transform: translateY(-200%);
	}
	.notification.show {
		animation-name: noti;
		animation-duration: 5s;
		animation-fill-mode: forwards;
	}
	@keyframes noti {
		0% {transform: translateY(-200%)}
		20% {transform: translateY(0%)}
		80% {transform: translateY(0%)}
		100% {transform: translateY(-200%)}
	}
	.disable_click {
		pointer-events: none;
	}

</style>

<script>
	const notification = document.querySelector('.notification');
	const text = document.getElementById('notiText');

	document.querySelectorAll('a[href="javascript:void(0)"]').forEach(link => {
		link.addEventListener('click', unfinishedPage);
	});

	function unfinishedPage(event){
		const a = event.currentTarget;
		event.preventDefault();
		notification.classList.remove('show');
		void notification.offsetWidth; 
		text.innerHTML = "Sorry, that page isn't finished yet";
		notification.classList.add('show');
		a.classList.add('disable_click');
		setTimeout(() => a.classList.remove('disable_click'), 5000);
	}

	const workButton = document.getElementById('workButton');
	const educationButton = document.getElementById('educationButton');
	const work = document.getElementById('work');
	const education = document.getElementById('education');

	educationButton.classList.add('active');

	workButton.addEventListener('click', () => {
		education.classList.add('hide');
		work.classList.remove('hide');
		workButton.classList.add('active');
		educationButton.classList.remove('active');
	});

	educationButton.addEventListener('click', () => {
		work.classList.add('hide');
		education.classList.remove('hide');
		workButton.classList.remove('active');
		educationButton.classList.add('active');
	});

	const emailBtn = document.getElementById('email');
	const dropdown = document.getElementById('dropdown');
	let hideTimeout;

	emailBtn.addEventListener('mouseenter', () => {
		clearTimeout(hideTimeout);
		setTimeout(() => {dropdown.style.display = 'block'}, 100);
	});
	emailBtn.addEventListener('mouseleave', () => {
		hideTimeout = setTimeout(() => dropdown.style.display = 'none', 100);
	});
	dropdown.addEventListener('mouseenter', () => {
		clearTimeout(hideTimeout);
	});
	dropdown.addEventListener('mouseleave', () => {
		hideTimeout = setTimeout(() => dropdown.style.display = 'none', 100);
	});
</script>
