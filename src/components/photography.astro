---
import { Image } from  'astro:assets'
import Camera from '../assets/camera.svg'

import Church1 from '../images/Photography/Church1.JPG'
import Church2 from '../images/Photography/Church2.JPG'
import Church3 from '../images/Photography/Church3.jpg'
import Church4 from '../images/Photography/Church4.jpg'

import MillenniumPark from '../images/Photography/Millennium park.jpg'
import Lake from '../images/Photography/Lake.jpg'
import Camping from '../images/Photography/Camping.jpg'
import Florida from '../images/Photography/Florida.jpg'
---
<div class="navBar">
	<ul>
		<li><a href="/">Home</a></li>
		<li><a href="/pageProjects">Projects</a></li>
		<li><a href="/photography">Photography</a></li>
	</ul>
	<div class="notification"><p id="notiText"></p></div>
</div>

<div id="popout" ><Image src={Church1} alt="popout" class="popout-image" /></div>

<div class="titleBar">
	<Image 
		src={Camera} 
		alt="Camera"
		width="100"
	/>
	<h1>Photography</h1>
</div>
				
<div class="bigDiv">
<!-- First 4 -->
	<div class="parent">
		<div class="div1"> 
			<Image
				src={Church1}
				alt="Church1"
				class="vertImage"
			/>
		</div>
		<div class="div2"> 
			<Image
				src={Church2}
				alt="Church2"
				class="vertImage"
			/>
		</div>
		<div class="div3">
			<Image
				src={Church3}
				alt="Church3"
				class="vertImage"
			/>
		</div>
		<div class="div4">
			<Image
				src={Church4}
				alt="Church4"
				class="vertImage"
			/>
		</div>
	</div>

<!-- Second 4 -->
	<div class="parent">
		<div class="div1"> 
			<Image
				src={MillenniumPark}
				alt="Park"
				class="vertImage"
			/>
		</div>
		<div class="div2"> 
			<Image
				src={Lake}
				alt="Lake"
				class="horImage"
			/>
		</div>
		<div class="div3">
			<Image
				src={Camping}
				alt="Camping"
				class="vertImage"
			/>
		</div>
		<div class="div4">
			<Image
				src={Florida}
				alt="Florida"
				class="horImage"
			/>
		</div>
	</div>
</div>

<style>
	html { font-size: 16px; }
	body {
		margin: 0;
		padding: 0;
		height: 100%;
		width: 100%;
	}
	body.noScroll {
		overflow: hidden;
	}
	.titleBar {
		display: inline-flex;
		gap: 20px;
		text-align: left;
		font-size: 70px;
		margin: 30px 14% 0 14%;
	}
	h1 {
		text-align: center;
	}
	.bigDiv {
		padding: 2% 14%;
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	/* Nav Bar */
	.navBar {
		display: flex;
		justify-content: center;
		align-items: center;
		width: 100%;
		height: 5%;
		border-bottom: 2px solid black;
		overflow: hidden;
	}
	ul li {
		float: left;
		list-style-type: none;
		transition: transform 0.2s ease;
	}
	ul li a {
		display: block;
		padding: 17px;
	}
	li:hover {
		transform: scale(1.5);
	}

	/* Grid */
	.parent {
		display:grid;
		grid-template-columns: repeat(5, 1fr);
		grid-template-rows: repeat(4, 1fr);
		grid-column-gap: 10px;
		grid-row-gap: 10px;
	}
	.div1 { 
		grid-area: 1 / 1 / 3 / 4; 
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
		height: 500px;
	}
	.div2 { 
		grid-area: 3 / 3 / 5 / 6; 
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
		height: 500px;
	}
	.div3 { 
		grid-area: 3 / 1 / 5 / 3; 
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
		height: 500px;
	}
	.div4 { 
		grid-area: 1 / 4 / 3 / 6; 
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
		height: 500px;
	}
	.vertImage {
		width: 100%;
	}
	.horImage {
		height: 100%;
	}

	/* Popout Window */
	#popout {
		display: none;
		position: fixed;
		z-index: 100;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: rgba(0,0,0,0.85);
		justify-content: center;
		align-items: center;
		overflow: auto;
	}
	.popout-image{
		display: inherit;
		max-width: 90vw;
		max-height: 90vh;
		object-fit: contain;
		margin: auto;
	}
</style>
<script>
	document.addEventListener('astro:page-load', () => {
		document.querySelectorAll('.horImage, .vertImage').forEach(picture => {
			picture.addEventListener('click', openPopup);
		});

		document.getElementById("popout").addEventListener('click', closePopup);
	});

	function openPopup(event){
		const bg = document.getElementById('popout');
		const image = bg.querySelector('.popout-image');
		image.src = event.target.src;
		bg.style.display = "flex";
		document.body.classList.add('noScroll')	
	}

	function closePopup() {
		const bg = document.getElementById('popout');
		bg.style.display = "none";
		document.body.classList.remove('noScroll')	
	}
</script>
